SERVICETITAN_ENV=integration
SERVICETITAN_CLIENT_ID=
SERVICETITAN_CLIENT_SECRET=
SERVICETITAN_APP_KEY=
SERVICETITAN_TENANT_ID=
SERVICETITAN_DRY_RUN=true
BOOKING_ALLOWED_ORIGIN=*

# Optional defaults for bookings
SERVICETITAN_BUSINESS_UNIT_ID=
SERVICETITAN_JOB_TYPE_ID=
SERVICETITAN_CAMPAIGN_ID=

# Use only if your account requires a booking provider path
SERVICETITAN_BOOKING_PATH_MODE=tenant
SERVICETITAN_BOOKING_PROVIDER=
