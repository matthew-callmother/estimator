        {
          "id": "addr_city",
          "label": "City",
          "input_type": "text",
          "required": true,
          "placeholder": "Frisco",
          "autocomplete": "address-level2"
        },
        {
          "id": "addr_state",
          "label": "State",
          "input_type": "text",
          "required": true,
          "placeholder": "TX",
          "autocomplete": "address-level1",
          "pattern": "^[A-Za-z]{2}$",
          "pattern_msg": "Use a 2-letter state code"
